generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model BinaryRecord {
  id               String   @id @default(uuid())
  participant_name String
  time_ms          Int
  created_at       DateTime @default(now())
}

model LogicGateRecord {
  id               String   @id @default(uuid())
  participant_name String
  time_ms          Int
  created_at       DateTime @default(now())
}
